# RMMS aggregator configuration (CLAUDE.md §5). Copy to .env (dev) or
# /etc/rmms/aggregator.env (prod, mode 0600). Documents shape only — NO real
# secrets, hosts, or certs in the repo.

# ── Tablet MQTT broker (mTLS) ──────────────────────────────────────────────
RMMS_BROKER_HOST=tablet.local
RMMS_BROKER_PORT=8883
RMMS_BROKER_CA_PATH=/etc/rmms/certs/ca.pem
RMMS_BROKER_CERT_PATH=/etc/rmms/certs/radxa.pem
RMMS_BROKER_KEY_PATH=/etc/rmms/certs/radxa.key

# ── Hospital FHIR endpoint + OAuth (leave token URL empty for dev/HAPI) ─────
RMMS_FHIR_ENDPOINT=https://fhir.example.org/fhir
RMMS_FHIR_OAUTH_TOKEN_URL=
RMMS_FHIR_OAUTH_CLIENT_ID=
RMMS_FHIR_OAUTH_CLIENT_SECRET=
RMMS_FHIR_OAUTH_SCOPES=system/Observation.write system/Patient.read system/Device.write

# ── Local persistence + behaviour ──────────────────────────────────────────
RMMS_DB_PATH=/var/lib/rmms/aggregator.db
RMMS_LOG_LEVEL=INFO
RMMS_HEALTH_PORT=9100
RMMS_ESTIMATED_TRANSPORT_LATENCY_MS=500
RMMS_PUBLISH_TIME_SYNC=true
